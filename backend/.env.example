# ============================================
# Configuración del Servidor
# ============================================
PORT=5000
MONGO_URI=mongodb://localhost:27017/royal_prestige

# ============================================
# Configuración SMTP para envío de correos (HU-005)
# ============================================
# Para Gmail:
# 1. Activar verificación en 2 pasos en tu cuenta de Google
# 2. Generar una contraseña de aplicación en: https://myaccount.google.com/apppasswords
# 3. Usar esa contraseña en SMTP_PASS (no usar la contraseña normal de Gmail)
#
# SMTP_HOST: Servidor SMTP (gmail: smtp.gmail.com, outlook: smtp.office365.com)
# SMTP_PORT: Puerto SMTP (587 para TLS, 465 para SSL)
# SMTP_USER: Correo electrónico que enviará los reportes
# SMTP_PASS: Contraseña de aplicación (no la contraseña normal)
# EMAIL_TO: Destinatarios separados por coma
# EMAIL_FROM: Remitente (usualmente el mismo que SMTP_USER)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu-correo@gmail.com
SMTP_PASS=tu-contraseña-de-aplicacion
EMAIL_TO=ventas@royalprestige.com,gerente@royalprestige.com
EMAIL_FROM=noreply@royalprestige.com

# ============================================
# API Key para proteger el endpoint de reporte (HU-005)
# ============================================
# Genera una clave segura con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Esta clave debe enviarse en el header: Authorization: Bearer <REPORTE_API_KEY>
REPORTE_API_KEY=tu-api-key-segura-aqui